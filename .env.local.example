# ---------------------------------------------------------------------------
# BidCopilot — environment. Copy to .env.local and fill in.
# ---------------------------------------------------------------------------

# Database
MONGODB_URI=

# Freelancer project source:
#   FREELANCER_MODE=mock -> sample projects, no network.
#   FREELANCER_MODE=rss  -> public RSS feed (NO token, NO account risk, ToS-safe). Recommended.
#   FREELANCER_MODE=live -> official API (needs FREELANCER_OAUTH_TOKEN from developers.freelancer.com).
FREELANCER_MODE=rss
FREELANCER_RSS_URL=https://www.freelancer.com/rss.xml
FREELANCER_OAUTH_TOKEN=
FREELANCER_API_BASE=https://www.freelancer.com/api

# AI for scoring + proposal generation (Phase 2). Provider-flexible.
#   AI_PROVIDER=gemini      + GEMINI_API_KEY      -> Google Gemini (FREE tier, aistudio.google.com)
#   AI_PROVIDER=openai      + OPENAI_API_KEY      -> ChatGPT (gpt-4o-mini default)
#   AI_PROVIDER=anthropic   + ANTHROPIC_API_KEY   -> Claude
#   (leave AI_PROVIDER blank to auto-pick whichever key is set)
#   no key -> mock mode (sample proposals, free)
# NOTE: API keys (platform.openai.com / console.anthropic.com / aistudio.google.com) are
#       separate from any ChatGPT Plus / Claude Max subscription.
AI_PROVIDER=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Account label shown in the sidebar
ACCOUNT_NAME=Stallioni

# Login security — one shared password to open the app, and a secret to sign the session cookie.
# Generate AUTH_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_PASSWORD=change-me
AUTH_SECRET=
